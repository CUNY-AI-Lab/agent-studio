      "content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <title>AI Research Subfields</title>\n  <link href=\"https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700&family=JetBrains+Mono:wght@400;500&display=swap\" rel=\"stylesheet\">\n  <style>\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n    \n    body {\n      font-family: 'Space Grotesk', sans-serif;\n      background: linear-gradient(145deg, #0f0f1a 0%, #1a1a2e 50%, #16213e 100%);\n      min-height: 100vh;\n      padding: 24px;\n      color: #e0e0e0;\n    }\n    \n    .container {\n      max-width: 900px;\n      margin: 0 auto;\n    }\n    \n    .header {\n      text-align: center;\n      margin-bottom: 24px;\n    }\n    \n    .header h1 {\n      font-size: 1.5rem;\n      font-weight: 700;\n      background: linear-gradient(135deg, #00d4ff, #7c3aed, #f472b6);\n      -webkit-background-clip: text;\n      -webkit-text-fill-color: transparent;\n      margin-bottom: 6px;\n    }\n    \n    .header p {\n      color: #888;\n      font-size: 0.9rem;\n    }\n    \n    .bubble-container {\n      display: flex;\n      flex-wrap: wrap;\n      justify-content: center;\n      align-items: center;\n      gap: 16px;\n      padding: 20px;\n    }\n    \n    .bubble {\n      position: relative;\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      justify-content: center;\n      border-radius: 50%;\n      cursor: pointer;\n      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n      animation: float 6s ease-in-out infinite;\n    }\n    \n    .bubble:nth-child(odd) { animation-delay: -3s; }\n    .bubble:nth-child(3n) { animation-delay: -1.5s; }\n    .bubble:nth-child(4n) { animation-delay: -4.5s; }\n    \n    @keyframes float {\n      0%, 100% { transform: translateY(0); }\n      50% { transform: translateY(-8px); }\n    }\n    \n    .bubble:hover {\n      transform: scale(1.08) translateY(-5px) !important;\n      z-index: 10;\n    }\n    \n    .bubble-inner {\n      position: absolute;\n      inset: 3px;\n      border-radius: 50%;\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      justify-content: center;\n      padding: 12px;\n      text-align: center;\n    }\n    \n    .bubble-label {\n      font-weight: 600;\n      font-size: 0.75rem;\n      line-height: 1.2;\n      margin-bottom: 4px;\n      text-shadow: 0 1px 2px rgba(0,0,0,0.5);\n    }\n    \n    .bubble-count {\n      font-family: 'JetBrains Mono', monospace;\n      font-size: 0.9rem;\n      font-weight: 500;\n      opacity: 0.9;\n    }\n    \n    .bubble-percent {\n      font-size: 0.65rem;\n      opacity: 0.7;\n      margin-top: 2px;\n    }\n    \n    /* Individual bubble colors */\n    .bubble-0 { \n      background: linear-gradient(135deg, #667eea, #764ba2);\n      box-shadow: 0 0 40px rgba(102, 126, 234, 0.4);\n    }\n    .bubble-0 .bubble-inner { background: linear-gradient(135deg, #667eea, #764ba2); }\n    \n    .bubble-1 { \n      background: linear-gradient(135deg, #f093fb, #f5576c);\n      box-shadow: 0 0 35px rgba(240, 147, 251, 0.4);\n    }\n    .bubble-1 .bubble-inner { background: linear-gradient(135deg, #f093fb, #f5576c); }\n    \n    .bubble-2 { \n      background: linear-gradient(135deg, #4facfe, #00f2fe);\n      box-shadow: 0 0 30px rgba(79, 172, 254, 0.4);\n    }\n    .bubble-2 .bubble-inner { background: linear-gradient(135deg, #4facfe, #00f2fe); }\n    \n    .bubble-3 { \n      background: linear-gradient(135deg, #43e97b, #38f9d7);\n      box-shadow: 0 0 28px rgba(67, 233, 123, 0.4);\n    }\n    .bubble-3 .bubble-inner { background: linear-gradient(135deg, #43e97b, #38f9d7); color: #1a1a2e; }\n    \n    .bubble-4 { \n      background: linear-gradient(135deg, #fa709a, #fee140);\n      box-shadow: 0 0 25px rgba(250, 112, 154, 0.4);\n    }\n    .bubble-4 .bubble-inner { background: linear-gradient(135deg, #fa709a, #fee140); color: #1a1a2e; }\n    \n    .bubble-5 { \n      background: linear-gradient(135deg, #a8edea, #fed6e3);\n      box-shadow: 0 0 22px rgba(168, 237, 234, 0.4);\n    }\n    .bubble-5 .bubble-inner { background: linear-gradient(135deg, #a8edea, #fed6e3); color: #1a1a2e; }\n    \n    .bubble-6 { \n      background: linear-gradient(135deg, #ff9a9e, #fecfef);\n      box-shadow: 0 0 20px rgba(255, 154, 158, 0.4);\n    }\n    .bubble-6 .bubble-inner { background: linear-gradient(135deg, #ff9a9e, #fecfef); color: #1a1a2e; }\n    \n    .bubble-7 { \n      background: linear-gradient(135deg, #ffecd2, #fcb69f);\n      box-shadow: 0 0 18px rgba(252, 182, 159, 0.4);\n    }\n    .bubble-7 .bubble-inner { background: linear-gradient(135deg, #ffecd2, #fcb69f); color: #1a1a2e; }\n    \n    .legend {\n      margin-top: 24px;\n      display: flex;\n      flex-wrap: wrap;\n      justify-content: center;\n      gap: 10px;\n    }\n    \n    .legend-item {\n      display: flex;\n      align-items: center;\n      gap: 6px;\n      background: rgba(255,255,255,0.05);\n      padding: 6px 12px;\n      border-radius: 20px;\n      font-size: 0.75rem;\n    }\n    \n    .legend-dot {\n      width: 10px;\n      height: 10px;\n      border-radius: 50%;\n    }\n    \n    .summary {\n      margin-top: 20px;\n      display: flex;\n      justify-content: center;\n      gap: 24px;\n      flex-wrap: wrap;\n    }\n    \n    .stat {\n      text-align: center;\n      padding: 12px 20px;\n      background: rgba(255,255,255,0.03);\n      border-radius: 12px;\n      border: 1px solid rgba(255,255,255,0.08);\n    }\n    \n    .stat-value {\n      font-family: 'JetBrains Mono', monospace;\n      font-size: 1.4rem;\n      font-weight: 700;\n      background: linear-gradient(135deg, #00d4ff, #7c3aed);\n      -webkit-background-clip: text;\n      -webkit-text-fill-color: transparent;\n    }\n    \n    .stat-label {\n      font-size: 0.7rem;\n      color: #888;\n      margin-top: 4px;\n      text-transform: uppercase;\n      letter-spacing: 0.5px;\n    }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <div class=\"header\">\n      <h1>🧠 AI Research Subfields</h1>\n      <p>Publications 2023-2025 • Bubble size = relative volume</p>\n    </div>\n    \n    <div class=\"bubble-container\">\n      \n          <div class=\"bubble bubble-0\" style=\"width: 180px; height: 180px;\">\n            <div class=\"bubble-inner\">\n              <span class=\"bubble-label\">Machine Learning</span>\n              <span class=\"bubble-count\">889K</span>\n              <span class=\"bubble-percent\">23.3%</span>\n            </div>\n          </div>\n        \n          <div class=\"bubble bubble-1\" style=\"width: 177.37794746226507px; height: 177.37794746226507px;\">\n            <div class=\"bubble-inner\">\n              <span class=\"bubble-label\">Deep Learning</span>\n              <span class=\"bubble-count\">866K</span>\n              <span class=\"bubble-percent\">22.7%</span>\n            </div>\n          </div>\n        \n          <div class=\"bubble bubble-2\" style=\"width: 161.3410770617902px; height: 161.3410770617902px;\">\n            <div class=\"bubble-inner\">\n              <span class=\"bubble-label\">Neural Networks</span>\n              <span class=\"bubble-count\">724K</span>\n              <span class=\"bubble-percent\">19.0%</span>\n            </div>\n          </div>\n        \n          <div class=\"bubble bubble-3\" style=\"width: 137.28402889732814px; height: 137.28402889732814px;\">\n            <div class=\"bubble-inner\">\n              <span class=\"bubble-label\">Large Language Models</span>\n              <span class=\"bubble-count\">510K</span>\n              <span class=\"bubble-percent\">13.4%</span>\n            </div>\n          </div>\n        \n          <div class=\"bubble bubble-4\" style=\"width: 117.94854153035321px; height: 117.94854153035321px;\">\n            <div class=\"bubble-inner\">\n              <span class=\"bubble-label\">Natural Language Processing</span>\n              <span class=\"bubble-count\">338K</span>\n              <span class=\"bubble-percent\">8.9%</span>\n            </div>\n          </div>\n        \n          <div class=\"bubble bubble-5\" style=\"width: 106.15723096502056px; height: 106.15723096502056px;\">\n            <div class=\"bubble-inner\">\n              <span class=\"bubble-label\">Computer Vision</span>\n              <span class=\"bubble-count\">233K</span>\n              <span class=\"bubble-percent\">6.1%</span>\n            </div>\n          </div>\n        \n          <div class=\"bubble bubble-6\" style=\"width: 97.80034491519898px; height: 97.80034491519898px;\">\n            <div class=\"bubble-inner\">\n              <span class=\"bubble-label\">Reinforcement Learning</span>\n              <span class=\"bubble-count\">158K</span>\n              <span class=\"bubble-percent\">4.2%</span>\n            </div>\n          </div>\n        \n          <div class=\"bubble bubble-7\" style=\"width: 90.64054394970624px; height: 90.64054394970624px;\">\n            <div class=\"bubble-inner\">\n              <span class=\"bubble-label\">Generative AI</span>\n              <span class=\"bubble-count\">95K</span>\n              <span class=\"bubble-percent\">2.5%</span>\n            </div>\n          </div>\n        \n    </div>\n    \n    <div class=\"summary\">\n      <div class=\"stat\">\n        <div class=\"stat-value\">3.8M</div>\n        <div class=\"stat-label\">Total Papers</div>\n      </div>\n      <div class=\"stat\">\n        <div class=\"stat-value\">#1</div>\n        <div class=\"stat-label\">Machine Learning</div>\n      </div>\n      <div class=\"stat\">\n        <div class=\"stat-value\">🚀 LLMs</div>\n        <div class=\"stat-label\">Fastest Growing</div>\n      </div>\n    </div>\n  </div>\n</body>\n</html>",

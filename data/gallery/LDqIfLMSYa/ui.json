      "title": "AI Research Trends",
      "content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>AI Research Trends</title>\n  <link href=\"https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap\" rel=\"stylesheet\">\n  <style>\n    * {\n      margin: 0;\n      padding: 0;\n      box-sizing: border-box;\n    }\n    \n    :root {\n      --bg-dark: #0c0c14;\n      --bg-card: #13131f;\n      --text-primary: #f0f0f5;\n      --text-secondary: #8888a0;\n      --accent: #6366f1;\n      --accent-glow: rgba(99, 102, 241, 0.4);\n      --gradient-start: #818cf8;\n      --gradient-end: #6366f1;\n      --bar-gradient-1: #6366f1;\n      --bar-gradient-2: #a855f7;\n      --peak-color: #22d3ee;\n    }\n    \n    body {\n      font-family: 'Space Grotesk', sans-serif;\n      background: var(--bg-dark);\n      color: var(--text-primary);\n      min-height: 100vh;\n      padding: 24px;\n      background-image: \n        radial-gradient(ellipse at 20% 0%, rgba(99, 102, 241, 0.15) 0%, transparent 50%),\n        radial-gradient(ellipse at 80% 100%, rgba(168, 85, 247, 0.1) 0%, transparent 50%);\n    }\n    \n    .container {\n      max-width: 800px;\n      margin: 0 auto;\n    }\n    \n    .header {\n      margin-bottom: 32px;\n      animation: fadeIn 0.6s ease-out;\n    }\n    \n    .header h1 {\n      font-size: 28px;\n      font-weight: 700;\n      letter-spacing: -0.5px;\n      background: linear-gradient(135deg, var(--gradient-start), var(--gradient-end));\n      -webkit-background-clip: text;\n      -webkit-text-fill-color: transparent;\n      background-clip: text;\n      margin-bottom: 8px;\n    }\n    \n    .header p {\n      color: var(--text-secondary);\n      font-size: 14px;\n      font-family: 'JetBrains Mono', monospace;\n    }\n    \n    .chart-container {\n      background: var(--bg-card);\n      border-radius: 16px;\n      padding: 32px;\n      border: 1px solid rgba(255, 255, 255, 0.05);\n      box-shadow: \n        0 4px 24px rgba(0, 0, 0, 0.3),\n        inset 0 1px 0 rgba(255, 255, 255, 0.05);\n      animation: slideUp 0.8s ease-out;\n    }\n    \n    .chart {\n      display: flex;\n      align-items: flex-end;\n      justify-content: space-between;\n      height: 280px;\n      padding-top: 20px;\n      gap: 16px;\n    }\n    \n    .bar-group {\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      flex: 1;\n      height: 100%;\n      justify-content: flex-end;\n    }\n    \n    .bar-wrapper {\n      width: 100%;\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      justify-content: flex-end;\n      flex: 1;\n      position: relative;\n    }\n    \n    .bar {\n      width: 100%;\n      max-width: 64px;\n      border-radius: 8px 8px 4px 4px;\n      background: linear-gradient(180deg, var(--bar-gradient-1) 0%, var(--bar-gradient-2) 100%);\n      position: relative;\n      transition: all 0.3s ease;\n      animation: growUp 1s ease-out forwards;\n      transform-origin: bottom;\n      opacity: 0;\n      box-shadow: \n        0 0 20px var(--accent-glow),\n        inset 0 1px 0 rgba(255, 255, 255, 0.2);\n    }\n    \n    .bar:hover {\n      transform: scaleY(1.02);\n      box-shadow: \n        0 0 30px var(--accent-glow),\n        0 0 60px rgba(99, 102, 241, 0.2),\n        inset 0 1px 0 rgba(255, 255, 255, 0.3);\n    }\n    \n    .bar.peak {\n      background: linear-gradient(180deg, #22d3ee 0%, #6366f1 100%);\n      box-shadow: \n        0 0 25px rgba(34, 211, 238, 0.4),\n        inset 0 1px 0 rgba(255, 255, 255, 0.3);\n    }\n    \n    .bar.current {\n      background: linear-gradient(180deg, var(--bar-gradient-1) 0%, var(--bar-gradient-2) 100%);\n      opacity: 0.7;\n      background-image: repeating-linear-gradient(\n        -45deg,\n        transparent,\n        transparent 4px,\n        rgba(255, 255, 255, 0.05) 4px,\n        rgba(255, 255, 255, 0.05) 8px\n      );\n    }\n    \n    .count-label {\n      font-family: 'JetBrains Mono', monospace;\n      font-size: 12px;\n      font-weight: 500;\n      color: var(--text-primary);\n      margin-bottom: 8px;\n      opacity: 0;\n      animation: fadeIn 0.5s ease-out forwards;\n      animation-delay: 1s;\n    }\n    \n    .year-label {\n      font-size: 14px;\n      font-weight: 600;\n      color: var(--text-secondary);\n      margin-top: 16px;\n      transition: color 0.3s ease;\n    }\n    \n    .bar-group:hover .year-label {\n      color: var(--text-primary);\n    }\n    \n    .legend {\n      display: flex;\n      justify-content: center;\n      gap: 24px;\n      margin-top: 28px;\n      padding-top: 20px;\n      border-top: 1px solid rgba(255, 255, 255, 0.05);\n      animation: fadeIn 1s ease-out 0.5s forwards;\n      opacity: 0;\n    }\n    \n    .legend-item {\n      display: flex;\n      align-items: center;\n      gap: 8px;\n      font-size: 12px;\n      color: var(--text-secondary);\n    }\n    \n    .legend-dot {\n      width: 10px;\n      height: 10px;\n      border-radius: 3px;\n    }\n    \n    .legend-dot.peak-legend {\n      background: linear-gradient(135deg, #22d3ee, #6366f1);\n    }\n    \n    .legend-dot.current-legend {\n      background: linear-gradient(135deg, var(--bar-gradient-1), var(--bar-gradient-2));\n      opacity: 0.7;\n    }\n    \n    .stats {\n      display: grid;\n      grid-template-columns: repeat(3, 1fr);\n      gap: 16px;\n      margin-top: 24px;\n      animation: fadeIn 1s ease-out 0.8s forwards;\n      opacity: 0;\n    }\n    \n    .stat-card {\n      background: rgba(255, 255, 255, 0.02);\n      border: 1px solid rgba(255, 255, 255, 0.05);\n      border-radius: 12px;\n      padding: 16px;\n      text-align: center;\n    }\n    \n    .stat-value {\n      font-size: 24px;\n      font-weight: 700;\n      color: var(--accent);\n      font-family: 'JetBrains Mono', monospace;\n    }\n    \n    .stat-label {\n      font-size: 11px;\n      color: var(--text-secondary);\n      text-transform: uppercase;\n      letter-spacing: 0.5px;\n      margin-top: 4px;\n    }\n    \n    @keyframes fadeIn {\n      from { opacity: 0; }\n      to { opacity: 1; }\n    }\n    \n    @keyframes slideUp {\n      from { \n        opacity: 0; \n        transform: translateY(20px); \n      }\n      to { \n        opacity: 1; \n        transform: translateY(0); \n      }\n    }\n    \n    @keyframes growUp {\n      from { \n        transform: scaleY(0);\n        opacity: 0;\n      }\n      to { \n        transform: scaleY(1);\n        opacity: 1;\n      }\n    }\n    \n    .bar-group:nth-child(1) .bar { animation-delay: 0.1s; }\n    .bar-group:nth-child(2) .bar { animation-delay: 0.2s; }\n    .bar-group:nth-child(3) .bar { animation-delay: 0.3s; }\n    .bar-group:nth-child(4) .bar { animation-delay: 0.4s; }\n    .bar-group:nth-child(5) .bar { animation-delay: 0.5s; }\n    .bar-group:nth-child(6) .bar { animation-delay: 0.6s; }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <div class=\"header\">\n      <h1>AI Research Publications</h1>\n      <p>// OpenAlex indexed papers • 2020-2025</p>\n    </div>\n    \n    <div class=\"chart-container\">\n      <div class=\"chart\">\n        \n            <div class=\"bar-group\">\n              <div class=\"bar-wrapper\">\n                <span class=\"count-label\">800K</span>\n                <div class=\"bar  \" \n                     style=\"height: 83.84385881840238%;\"\n                     title=\"2020: 800,350 papers\"></div>\n              </div>\n              <span class=\"year-label\">2020</span>\n            </div>\n          \n            <div class=\"bar-group\">\n              <div class=\"bar-wrapper\">\n                <span class=\"count-label\">849K</span>\n                <div class=\"bar  \" \n                     style=\"height: 88.90895605569827%;\"\n                     title=\"2021: 848,700 papers\"></div>\n              </div>\n              <span class=\"year-label\">2021</span>\n            </div>\n          \n            <div class=\"bar-group\">\n              <div class=\"bar-wrapper\">\n                <span class=\"count-label\">835K</span>\n                <div class=\"bar  \" \n                     style=\"height: 87.51052827864216%;\"\n                     title=\"2022: 835,351 papers\"></div>\n              </div>\n              <span class=\"year-label\">2022</span>\n            </div>\n          \n            <div class=\"bar-group\">\n              <div class=\"bar-wrapper\">\n                <span class=\"count-label\">955K</span>\n                <div class=\"bar peak \" \n                     style=\"height: 100%;\"\n                     title=\"2023: 954,572 papers\"></div>\n              </div>\n              <span class=\"year-label\">2023</span>\n            </div>\n          \n            <div class=\"bar-group\">\n              <div class=\"bar-wrapper\">\n                <span class=\"count-label\">906K</span>\n                <div class=\"bar  \" \n                     style=\"height: 94.86188574565355%;\"\n                     title=\"2024: 905,525 papers\"></div>\n              </div>\n              <span class=\"year-label\">2024</span>\n            </div>\n          \n            <div class=\"bar-group\">\n              <div class=\"bar-wrapper\">\n                <span class=\"count-label\">708K</span>\n                <div class=\"bar  current\" \n                     style=\"height: 74.12023398968334%;\"\n                     title=\"2025: 707,531 papers\"></div>\n              </div>\n              <span class=\"year-label\">2025</span>\n            </div>\n          \n      </div>\n      \n      <div class=\"legend\">\n        <div class=\"legend-item\">\n          <div class=\"legend-dot peak-legend\"></div>\n          <span>Peak Year (2023)</span>\n        </div>\n        <div class=\"legend-item\">\n          <div class=\"legend-dot current-legend\"></div>\n          <span>2025 (In Progress)</span>\n        </div>\n      </div>\n      \n      <div class=\"stats\">\n        <div class=\"stat-card\">\n          <div class=\"stat-value\">954K</div>\n          <div class=\"stat-label\">Peak Year (2023)</div>\n        </div>\n        <div class=\"stat-card\">\n          <div class=\"stat-value\">+19%</div>\n          <div class=\"stat-label\">Growth 2020→2023</div>\n        </div>\n        <div class=\"stat-card\">\n          <div class=\"stat-value\">4.25M</div>\n          <div class=\"stat-label\">Total Papers</div>\n        </div>\n      </div>\n    </div>\n  </div>\n</body>\n</html>",

{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "agent-studio",
  "main": "src/server.ts",
  "compatibility_date": "2026-03-25",
  "compatibility_flags": ["nodejs_compat"],
  "build": {
    "command": "bun run --cwd ../frontend build",
    "cwd": ".",
    "watch_dir": ["src", "../frontend/src", "../frontend/index.html"]
  },
  "worker_loaders": [
    {
      "binding": "LOADER"
    }
  ],
  "assets": {
    "directory": "../frontend/dist",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*", "/agents/*", "/health"],
    "not_found_handling": "single-page-application",
    "html_handling": "auto-trailing-slash"
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "WorkspaceAgent",
        "class_name": "WorkspaceAgent"
      },
      {
        // First-login migration claims (anonymous namespace -> CAIL subject),
        // one instance per anonymous session id. See src/migration-registry.ts.
        "name": "MIGRATION_REGISTRY",
        "class_name": "MigrationRegistry"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["WorkspaceAgent"]
    },
    {
      "tag": "v2",
      "new_sqlite_classes": ["MigrationRegistry"]
    }
  ],
  "r2_buckets": [
    {
      "binding": "WORKSPACE_FILES",
      // Production data. `bucket_name` is the ONLY binding that touches real
      // user workspaces/sessions/gallery objects.
      "bucket_name": "agent-studio",
      // Isolation: `wrangler dev --remote` and preview/versioned deploys bind
      // `preview_bucket_name` instead of `bucket_name`. This MUST be a distinct
      // bucket so remote/preview reads/writes/DELETEs (deleteByPrefix, the
      // first-login migration copy/delete) never touch production data — they
      // share the `agent-studio/sessions/` key prefix otherwise. Create it once
      // before remote/preview dev: `wrangler r2 bucket create agent-studio-preview`.
      "preview_bucket_name": "agent-studio-preview"
    }
  ],
  // Rate Limiting bindings for the HTTP /api/* surface (see src/lib/rate-limit.ts).
  // Counting is PER-COLO (each Cloudflare data center counts independently) and
  // zero-latency — acceptable for launch scale, not a global hard cap. Keyed by
  // session id, not IP. FAIL-OPEN CONTRACT: the middleware declares these
  // bindings optional and skips limiting entirely when absent, so local dev /
  // tests / miniflare quirks stay usable. namespace_id values (4001/4002) are
  // arbitrary but must not collide with each other.
  "unsafe": {
    "bindings": [
      {
        "name": "API_RATE_LIMIT",
        "type": "ratelimit",
        "namespace_id": "4001",
        "simple": { "limit": 300, "period": 60 }
      },
      {
        "name": "HEAVY_RATE_LIMIT",
        "type": "ratelimit",
        "namespace_id": "4002",
        "simple": { "limit": 20, "period": 60 }
      }
    ]
  },
  "vars": {
    // CAIL model proxy base URL (serves /v1/... and /keys). Placeholder until
    // launch — set to the institutional model-proxy URL per
    // cail-gateway docs/LAUNCH_CHECKLIST.md. No trailing slash.
    "CAIL_API_BASE": "https://REPLACE-WITH-CAIL-MODEL-PROXY.invalid",
    // Optional model override; the proxy/AI Gateway resolves this slug.
    // CAIL policy: Workers AI catalog (@cf/...) ids only. Defaults to
    // @cf/zai-org/glm-5.2 when unset (see src/lib/cail-model.ts).
    "CAIL_MODEL": "@cf/zai-org/glm-5.2",
    // Fail closed: reject anonymous model calls with 401. Turn on ("true") at
    // the same time CAIL_SSO_MODE=enforce lands on the gateway. Left "false"
    // pre-rollout so local/dev without the gate stays usable.
    // CAIL_BASE_PATH and CAIL_CANONICAL_ORIGIN are injected at deploy for the
    // shared host (mirroring the existing canonical-origin handling) rather
    // than checked in: local dev serves at '/'. Leaving CAIL_BASE_PATH unset on
    // that shared host makes the script-readable CSRF cookie host-wide.
    "CAIL_REQUIRE_IDENTITY": "false"
  },
  // Secrets (never in this file; set via `wrangler secret put`):
  //   SESSION_SECRET             - random 32-byte hex for the signed session cookie.
  //   CAIL_IDENTITY_JWT_SECRET   - shared HS256 secret used to VERIFY the
  //                                X-CAIL-Identity-JWT the SSO gate injects.
  //                                Ops-managed (cail-gateway push-secrets.sh);
  //                                identical to the value the model proxy and
  //                                key service use. Never in code.
  //   GIT_AUTH_TOKEN (optional)  - token for git tools inside the runtime.
  // Agent Studio holds NO provider API key: all model calls go through the CAIL
  // model proxy with the caller's identity JWT (see src/lib/cail-model.ts).
  "observability": {
    "enabled": true
  }
}

{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "agent-studio",
  "account_id": "452c33847cf5cb1e46f391fca32fd1b5",
  "main": "src/server.ts",
  "compatibility_date": "2026-03-25",
  "compatibility_flags": ["nodejs_compat"],
  "build": {
    "command": "VITE_BASE_PATH=/agent-studio bun run --cwd ../frontend build",
    "cwd": ".",
    "watch_dir": ["src", "../frontend/src", "../frontend/index.html"]
  },
  "worker_loaders": [
    {
      "binding": "LOADER"
    }
  ],
  "assets": {
    "directory": "../frontend/dist",
    "binding": "ASSETS",
    "run_worker_first": ["/*"],
    "not_found_handling": "single-page-application",
    "html_handling": "auto-trailing-slash"
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "WorkspaceAgent",
        "class_name": "WorkspaceAgent"
      },
      {
        // First-login migration claims (anonymous namespace -> CAIL subject),
        // one instance per anonymous session id. See src/migration-registry.ts.
        "name": "MIGRATION_REGISTRY",
        "class_name": "MigrationRegistry"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["WorkspaceAgent"]
    },
    {
      "tag": "v2",
      "new_sqlite_classes": ["MigrationRegistry"]
    }
  ],
  "r2_buckets": [
    {
      "binding": "WORKSPACE_FILES",
      // Production data. `bucket_name` is the ONLY binding that touches real
      // user workspaces/sessions/gallery objects.
      "bucket_name": "agent-studio",
      // Isolation: `wrangler dev --remote` and preview/versioned deploys bind
      // `preview_bucket_name` instead of `bucket_name`. This MUST be a distinct
      // bucket so remote/preview reads/writes/DELETEs (deleteByPrefix, the
      // first-login migration copy/delete) never touch production data — they
      // share the `agent-studio/sessions/` key prefix otherwise. Create it once
      // before remote/preview dev: `wrangler r2 bucket create agent-studio-preview`.
      "preview_bucket_name": "agent-studio-preview"
    }
  ],
  // Source declaration only. Cloudflare creates the Analytics Engine dataset
  // on the first write after an authorized deployment; this repository task
  // does not deploy or create any live resource.
  "analytics_engine_datasets": [
    {
      "binding": "CAIL_FLEET_EVENTS",
      "dataset": "cail_fleet_events_v1"
    }
  ],
  // Rate Limiting bindings for the HTTP /api/* surface (see src/lib/rate-limit.ts).
  // Counting is PER-COLO (each Cloudflare data center counts independently) and
  // zero-latency — acceptable for launch scale, not a global hard cap. Keyed by
  // session id, not IP. FAIL-OPEN CONTRACT: the middleware declares these
  // bindings optional and skips limiting entirely when absent, so local dev /
  // tests / miniflare quirks stay usable. namespace_id values (4001/4002) are
  // arbitrary but must not collide with each other.
  "unsafe": {
    "bindings": [
      {
        "name": "API_RATE_LIMIT",
        "type": "ratelimit",
        "namespace_id": "4001",
        "simple": { "limit": 300, "period": 60 }
      },
      {
        "name": "HEAVY_RATE_LIMIT",
        "type": "ratelimit",
        "namespace_id": "4002",
        "simple": { "limit": 20, "period": 60 }
      }
    ]
  },
  "vars": {
    // Institutional CAIL model proxy base URL (serves /v1/... and /keys).
    // No trailing slash.
    "CAIL_API_BASE": "https://cail-model-proxy.ailab-452.workers.dev",
    // Optional model override; the proxy/AI Gateway resolves this slug.
    // CAIL policy: Workers AI catalog (@cf/...) ids only. Defaults to
    // @cf/zai-org/glm-5.2 when unset (see src/lib/cail-model.ts).
    "CAIL_MODEL": "@cf/zai-org/glm-5.2",
    // Identity 3.0 trusts exactly one issuer per environment. Staging must
    // override this with https://tools.cuny.qzz.io/cail-sso.
    "CAIL_IDENTITY_ISSUER": "https://tools.ailab.gc.cuny.edu/cail-sso",
    // Required production telemetry classification. Local development overrides
    // this with `development` in .dev.vars.
    "CAIL_LOG_ENV": "production",
    // Shared-host routing is source-controlled. This value is deliberately
    // false so the checked-in file cannot serve production traffic: production
    // preflight requires true plus valid JWKS, canonical origin, migration
    // instants, rate bindings, gallery-owner keyring, and secrets.
    "CAIL_BASE_PATH": "/agent-studio",
    "CAIL_REQUIRE_IDENTITY": "false"
  },
  // Secrets (never in this file; set via `wrangler secret put`):
  //   SESSION_SECRET             - random 32-byte hex for the signed session cookie.
  //   CAIL_IDENTITY_JWKS         - static public JWKS JSON used to VERIFY the
  //                                RS256 X-CAIL-Identity-JWT for audience
  //                                cail:agent-studio. Distinct kid values may
  //                                overlap during signing-key rotation.
  //   CAIL_CANONICAL_ORIGIN      - exact public HTTPS origin, no path/query.
  //   CAIL_SSO_SWITCHED_AT       - complete identity switch instant.
  //   CAIL_ACCOUNT_IMPORT_UNTIL  - exclusive compatibility deadline (<=30d).
  //   GALLERY_OWNER_KEYS         - JSON versioned HMAC keyring; retain old ids.
  //   GALLERY_OWNER_ACTIVE_KEY_ID - key id used for new private owner records.
  //   GIT_AUTH_TOKEN (optional)  - token for git tools inside the runtime.
  //   GIT_AUTH_ALLOWED_HOSTS     - exact comma-separated credential hosts.
  // Agent Studio holds NO provider API key: all model calls go through the CAIL
  // model proxy with the caller's identity JWT (see src/lib/cail-model.ts).
  "observability": {
    "enabled": true,
    "logs": {
      // Raw invocation records include request URLs and platform metadata.
      // Studio emits its own bounded, content-free structured events instead.
      "enabled": true,
      "head_sampling_rate": 1,
      "invocation_logs": false,
      "persist": true,
      "destinations": []
    },
    "traces": {
      "enabled": false,
      "head_sampling_rate": 0,
      "persist": false,
      "destinations": []
    }
  },
  "logpush": false,
  "tail_consumers": [],
  "streaming_tail_consumers": [],
  "version_metadata": {
    "binding": "CF_VERSION_METADATA"
  }
}

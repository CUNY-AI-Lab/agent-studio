# Any string of 32+ characters works; generate with `openssl rand -hex 32`.
# This placeholder is intentionally too short so an uncustomized copy fails
# loud at request time instead of running with a known secret.
SESSION_SECRET=replace-me-openssl-rand-hex-32

# CAIL model proxy base URL (serves /v1/... and /keys). Placeholder until
# launch — see cail-gateway docs/LAUNCH_CHECKLIST.md. No trailing slash.
CAIL_API_BASE=https://REPLACE-WITH-CAIL-MODEL-PROXY.invalid
# Optional model override; the proxy/AI Gateway resolves this slug.
# CAIL policy: Workers AI catalog (@cf/...) ids only.
CAIL_MODEL=@cf/zai-org/glm-5.2
# Shared HS256 secret used to VERIFY the X-CAIL-Identity-JWT the SSO gate
# injects. Same value the model proxy and key service use (ops-managed).
# Leave blank locally to run anonymous (identity disabled).
CAIL_IDENTITY_JWT_SECRET=
# Static public JWKS JSON used to VERIFY X-CAIL-Identity-JWT-V2 (RS256,
# audience cail:agent-studio). V2 takes strict precedence when its header is
# present; missing/malformed JWKS or an invalid V2 token never falls back to V1.
# Multiple distinct kid values support signing-key rotation overlap.
CAIL_IDENTITY_JWKS=
# Fail closed: reject anonymous model calls with 401. Set "true" when
# CAIL_SSO_MODE=enforce lands on the gateway. If neither verifier is configured,
# or configured key material cannot verify a presented token, all requests fail.
CAIL_REQUIRE_IDENTITY=false

# Base path this tool is served under (fleet contract §3¾ rule 3 delivery
# amendment). Scopes the Path of the CSRF cookie (cail_csrf_agentstudio) so
# sibling tools / user content on tools.ailab can't read the token via
# document.cookie. Production on tools.ailab sets /agent-studio; leave unset
# ('/' default) locally / on workers.dev, where there are no same-origin
# siblings. See src/lib/csrf.ts.
CAIL_BASE_PATH=

GIT_AUTH_TOKEN=

# CUNY Primo (Ex Libris) search API — optional. When set, web_fetch attaches
# apikey/vid/scope server-side for this host; the agent never sees the key.
# PRIMO_API_BASE example: https://api-na.hosted.exlibrisgroup.com/primo/v1/search
PRIMO_API_BASE=
PRIMO_API_KEY=
PRIMO_VID=
PRIMO_SCOPE=

# OCLC WorldCat Search/Metadata API — optional. When set, web_fetch exchanges
# the client id/secret for a bearer token server-side and attaches it to the
# WorldCat API host; the agent never sees the credentials. Values come from the
# ops LAUNCH_CHECKLIST at deploy (canonical source ~/Apps/library-tools/.env).
OCLC_CLIENT_ID=
OCLC_CLIENT_SECRET=
OCLC_INSTITUTION_ID=

# Springshare LibGuides API — optional. Same server-side bearer pattern; the API
# host is derived from LIBGUIDES_BASE_URL. Values come from the ops checklist at
# deploy. LIBGUIDES_BASE_URL example: https://lgapi-us.libapps.com/1.2
LIBGUIDES_BASE_URL=
LIBGUIDES_CLIENT_ID=
LIBGUIDES_CLIENT_SECRET=
LIBGUIDES_SITE_ID=

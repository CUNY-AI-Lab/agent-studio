{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": ".runner-dist",
    "rootDir": ".",
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2022",
    "lib": ["es2022", "dom"],
    "incremental": false,
    "isolatedModules": false,
    "plugins": []
  },
  "include": [
    "src/runner/**/*.ts",
    "src/lib/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "src/lib/session/index.ts"
  ]
}
